<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      MinSize="465 265">
    <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">
        <BoxContainer Name="ImpersonationRow" Orientation="Horizontal" Margin="8 8 8 0">
            <LineEdit Name="ImpersonationInput"
                      HorizontalExpand="True"
                      PlaceHolder="{Loc callable-phone-impersonation-placeholder}" />
            <Button Name="ImpersonationApply"
                    Text="{Loc callable-phone-impersonation-apply}"
                    Margin="4 0 0 0" />
        </BoxContainer>
        <OutputPanel Name="TextOutput" VerticalExpand="True" Margin="8 8 8 4" />
        <LineEdit Name="Input" PlaceHolder="{Loc callable-phone-chat-input-placeholder}" Margin="8 4 8 8" />
    </BoxContainer>
</controls:FancyWindow>

