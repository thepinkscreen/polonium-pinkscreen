<controls:FancyWindow xmlns="https://spacestation14.io"
               xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
               Resizable="False"
               MaxSize="400 600"
               MinSize="400 200">
    <BoxContainer Orientation="Vertical" VerticalExpand="True" HorizontalExpand="True">

        <BoxContainer Name="ActiveCallControlsContainer" Orientation="Vertical" VerticalExpand="True" HorizontalExpand="True" ReservesSpace="False">
            <BoxContainer MinHeight="60" Orientation="Vertical" VerticalAlignment="Center">
                <Label Name="CallStatusText" Margin="10 5 10 0" ReservesSpace="False"/>
                <BoxContainer Name="CallerIdContainer" Orientation="Vertical" ReservesSpace="False" Visible="False">
                    <RichTextLabel Name="CallerIdText" HorizontalAlignment="Center" Margin="0 0 0 0"/>
                    <Label Text="{Loc 'callable-phone-window-relay-label'}" Margin="10 10 10 0" ReservesSpace="False"/>
                    <RichTextLabel Name="DeviceIdText" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                </BoxContainer>
            </BoxContainer>

            <GridContainer Columns="2" ReservesSpace="False">
                <Control HorizontalExpand="True" Margin="10 0 2 5">
                    <Button Name="AnswerCallButton" Text="{Loc 'callable-phone-window-answer-call'}" StyleClasses="OpenRight" Margin="0 0 0 5" Disabled="True"/>
                </Control>
                <Control HorizontalExpand="True" Margin="2 0 10 5">
                    <Button Name="EndCallButton" Text="{Loc 'callable-phone-window-end-call'}" StyleClasses="OpenLeft" Margin="0 0 0 5" Disabled="True"/>
                </Control>
            </GridContainer>
        </BoxContainer>

        <BoxContainer Name="CallPlacementControlsContainer" Orientation="Vertical" VerticalExpand="True" HorizontalExpand="True" ReservesSpace="False">

            <controls:StripeBack>
                <PanelContainer>
                    <RichTextLabel Name="SubtitleText" HorizontalAlignment="Center" Margin="0 5 0 5"/>
                </PanelContainer>
            </controls:StripeBack>

            <BoxContainer Name="ContactListContainer" Orientation="Vertical" Margin="10 0 10 5" ReservesSpace="False">
                <PanelContainer Name="ContactListHeaderPanel">
                    <Label Text="{Loc 'callable-phone-select-contact'}" HorizontalAlignment="Center" Margin="0 3 0 3"/>
                </PanelContainer>

                <PanelContainer Name="ContactListPanel">
                    <BoxContainer Orientation="Vertical">
                        <LineEdit Name="SearchLineEdit" HorizontalExpand="True" Margin="4, 4, 4, 0"
                                  PlaceHolder="{Loc callable-phone-window-filter-line-placeholder}" />
                        <ScrollContainer HorizontalExpand="True" VerticalExpand="True" Margin="8, 8, 8, 8" MinHeight="200">
                            <BoxContainer Name="FetchingContactsContainer" HorizontalAlignment="Center" HorizontalExpand="True" VerticalExpand="True" ReservesSpace="False">
                                <Label Text="{Loc 'callable-phone-window-fetching-contacts-list'}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </BoxContainer>
                            <BoxContainer Name="ContactsList" Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True" Margin="10 0 10 0"/>
                        </ScrollContainer>
                    </BoxContainer>
                </PanelContainer>
            </BoxContainer>

            <Button Name="CallButton" Text="{Loc 'callable-phone-call'}" Margin="10 0 10 5" Disabled="True"/>
        </BoxContainer>

        <BoxContainer Orientation="Vertical">
            <PanelContainer StyleClasses="LowDivider" />
            <Label Text="{Loc 'callable-phone-window-footer'}" StyleClasses="WindowFooterText" Margin="10 2 10 5" HorizontalAlignment="Center"/>
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
