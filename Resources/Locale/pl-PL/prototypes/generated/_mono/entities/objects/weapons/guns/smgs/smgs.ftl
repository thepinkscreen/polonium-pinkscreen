ent-WeaponSubMachineGunMla73 = SKR-WS MLA-73
    .desc = Niezawodny PDW, często wydawany pilotom i załogom pojazdów. Zmodyfikowany o wbudowany tłumik. Plotki głoszą, że to schemat z ery korporacyjnej, budowany przez Dynastię Phaethon. Szyny Erebus na górze i spodzie łoża na optykę i chwyty. Amunicja: { ent-CartridgeCaselessRifle }.
ent-WeaponSubMachineGunAK220 = NCI AK-220
    .desc = Masowo produkowany pistolet maszynowy bullpup. Projekt pochodzi z USSP, lecz licencjonują go producenci TSF i PDV lub budują podejrzanie podobne "oryginały". Amunicja: { ent-CartridgePistol }.
ent-WeaponSubMachineGunVector9x19mm = LWC Vector
    .desc = Doskonały pistolet maszynowy z ogniem ciągłym. Szyny Erebus na górze komory zamkowej i spodzie łoża. Amunicja: { ent-CartridgePistol }.
ent-WeaponSubMachineGunVector45_ACP = LWC Vector
    .desc = Doskonały pistolet maszynowy z ogniem ciągłym. Szyny Erebus na górze komory zamkowej i spodzie łoża. Amunicja: { ent-CartridgePistol }.
ent-WeaponSubMachineGunVectorNtsfHclm = NTSF-HCLM-45
    .desc = NTSF Heavy Caliber Light Machinegun — bardzo wysokiej jakości ciężki PM dla Nano Trasen Security Force i spec-ops NT z ery wojen korporacyjnych. Amunicja: { ent-CartridgeMagnum }.
ent-WeaponSubMachineGunKnallstock = LWC Knallstock
    .desc = Wytrzymały, niezawodny PM z długimi seriami. Uważaj na zużycie amunicji. Amunicja: { ent-CartridgePistol }.
ent-WeaponSubMachineGunTypewriterPMC = PA Keyboard
    .desc = Nowoczesna wersja klasyki gangsterów kosmosu. Mercenacka podróbka "maszyny do pisania" o przezwisku "keyboard" — lufa szybko się grzeje i spada celność. Amunicja: { ent-CartridgePistol }.
ent-WeaponSubMachineGunFirestarter = HWM Firestarter
    .desc = Doskonały pistolet maszynowy z ogniem ciągłym. Amunicja: { ent-CartridgePistol }.
ent-WeaponSubMachineGunMalandro = RS-2 Malandro
    .desc = Zniszczony, wytrzymały PM do walki na krótkim dystansie; 10-strzałowa seria kosztem celności. Amunicja: { ent-CartridgePistol }.
